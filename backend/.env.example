# ParkSense AI Backend Configuration
APP_NAME=ParkSense AI
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=sqlite:///./data/parksense.db

# Data paths
VIOLATIONS_CSV_PATH=../jan to may police violation_anonymized791b166 (2).csv

# Economic constants (INR)
FUEL_BURN_LPH=0.5
FUEL_COST_PER_L=103
AVERAGE_WAGE_PER_HOUR=350

# External API keys (optional — enables live Bengaluru traffic speeds)
GOOGLE_MAPS_API_KEY=
TOMTOM_API_KEY=
WEATHER_API_KEY=

# Live mode
LIVE_MODE=true
LIVE_REPLAY_ENABLED=true
LIVE_REPLAY_BATCH_SIZE=2
LIVE_REFRESH_SECONDS=30
