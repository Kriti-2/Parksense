# मार्ग Sense Backend Configuration
APP_NAME=मार्ग Sense
APP_ENV=development
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=sqlite:///./data/margsense.db

# Data paths
VIOLATIONS_CSV_PATH=../jan to may police violation_anonymized791b166 (2).csv

# Economic constants (INR)
FUEL_BURN_LPH=0.5
FUEL_COST_PER_L=103
AVERAGE_WAGE_PER_HOUR=350

# JWT & OAuth
JWT_SECRET=change-me-to-a-long-random-string-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# External API keys (optional — enables live Bengaluru traffic speeds)
GOOGLE_MAPS_API_KEY=
TOMTOM_API_KEY=
WEATHER_API_KEY=

# Live mode
LIVE_MODE=true
LIVE_REPLAY_ENABLED=true
LIVE_REPLAY_BATCH_SIZE=2
LIVE_REFRESH_SECONDS=30

# Phase 2 — Auth (set AUTH_ENABLED=true in production)
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
INGEST_API_KEY=
OFFICER_USERNAME=officer
OFFICER_PASSWORD=margsense-demo
INGEST_USERNAME=btp-ingest
INGEST_PASSWORD=margsense-ingest

# Phase 2 — Rate limits
RATE_LIMIT_PUBLIC=120/minute
RATE_LIMIT_INGEST=60/minute
RATE_LIMIT_OFFICER=100/minute
RATE_LIMIT_AUTH=20/minute

# Phase 2 — Celery / Redis (enable in Docker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_ENABLED=false
